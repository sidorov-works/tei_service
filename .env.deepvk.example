# .env.deepvk.example

ENCODER_NAME=deepvk

INTERNAL_API_SECRET=*****

ENCODER_SERVICE_PORT=8261 # в коде не используется, нужно только для запуска с procfile

DEVICE=mps

HUGGING_FACE_MODEL_NAME="deepvk/USER2-base"
VECTOR_SIZE=768
MAX_SEQ_LENGTH=8192
QUERY_PREFIX="search_query: "
DOCUMENT_PREFIX="search_document: "